<% layout('/layouts/boilerPlates') -%>

<div class="container mt-5">
  <h2 class="text-center mb-4">Listing Details</h2>

  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-lg border-0">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          alt="listing_image"
          style="height: 350px; object-fit: cover"
        />

        <div class="card-body">
          <h3 class="card-title"><%= listing.title %></h3>

          <p class="card-text text-muted"><%= listing.description %></p>

          <hr />

          <p>
            <strong>Price:</strong>
            ₹ <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>
          </p>

          <p>
            <strong>Location:</strong>
            <%= listing.location %>
          </p>

          <p>
            <strong>Country:</strong>
            <%= listing.country %>
          </p>
          <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex gap-2 mt-4">
            <a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">
              Edit
            </a>

            <form
              method="POST"
              action="/listings/<%= listing._id %>?_method=DELETE"
            >
              <button class="btn btn-danger">Delete</button>
            </form>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <hr class="mt-5" />

  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      <% if(currUser) {%>
      <h4 class="mb-3">Leave a Review</h4>

      <form method="POST" action="/listings/<%= listing._id %>/reviews" novalidate class="needs-validation">
        <!-- Rating -->
     <div class="mb-3">
    <label class="form-label">Rating</label>
    <div class="star-rating">
        <input type="radio" name="review[rating]" value="5" id="star5" required>
        <label for="star5"><i class="bi bi-star-fill"></i></label>

        <input type="radio" name="review[rating]" value="4" id="star4" required>
        <label for="star4"><i class="bi bi-star-fill"></i></label>

        <input type="radio" name="review[rating]" value="3" id="star3" required>
        <label for="star3"><i class="bi bi-star-fill"></i></label>

        <input type="radio" name="review[rating]" value="2" id="star2" required>
        <label for="star2"><i class="bi bi-star-fill"></i></label>

        <input type="radio" name="review[rating]" value="1" id="star1" required>
        <label for="star1"><i class="bi bi-star-fill"></i></label>
    </div>
</div>
        

        <!-- Comment -->
        <div class="mb-3">
          <label for="comment" class="form-label">Comment</label>
         <textarea
          class="form-control"
          id="comment"
          name="review[comment]"
          required
        ></textarea>

        <!-- Submit Button -->
        <button type="submit" class="btn btn-dark">Submit Review</button>
            <% } %>
      </form>
    </div>

    <hr class="mt-5">

  <h4 class="mb-3">Reviews</h4>

<div class="row">
  <% for(let review of listing.reviews) { %>
    <div class="col-md-4 mb-1">
      <div class="card border border-dark h-100">
         <div class="card-body d-flex flex-column">
          <h6>
              <i class="fa-solid fa-user"></i>
              <%= review.author.username %>
          </h6>
          <h6>⭐ <%= review.rating %>/5</h6>
          <p class="card-text"><%= review.comment %></p>

         <% if (
              currUser &&
              (
                  listing.owner.equals(currUser._id) ||
                  review.author._id.equals(currUser._id)
              )
          ) { %>
              <form
                  method="POST"
                  action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              >
                  <button class="btn btn-danger btn-sm">Delete</button>
              </form>
          <% } %>
        </div>
      </div>
    </div>
  <% } %>
</div>
</div>
