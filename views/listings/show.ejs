<% layout('/layouts/boilerPlates') -%>

<script>
    const coordinates =
        <%- JSON.stringify(
            listing.geometry &&
            Array.isArray(listing.geometry.coordinates) &&
            listing.geometry.coordinates.length === 2
                ? listing.geometry.coordinates
                : [75.7873, 26.9124]
        ) %>;
</script>


<div class="container mt-5">
  <h2 class="text-center mb-4">Listing Details</h2>

  <!-- Listing Card -->
  <div class="row justify-content-center">
    
    <div class="col-md-8 col-lg-6">
      <div class="card shadow-lg border-0">
        <img
          src="<%= listing.image.url %>"
          class="card-img-top"
          alt="listing_image"
          style="height:350px; object-fit:cover;"
        >

        <div class="card-body">
          <h3><%= listing.title %></h3>

          <p class="text-muted">
            <%= listing.description %>
          </p>

          <hr>

          <p>
            <strong>Price:</strong>
            ₹ <%= listing.price.toLocaleString("en-IN") %>
          </p>

          <p>
            <strong>Location:</strong>
            <%= listing.location %>
          </p>

          <p>
            <strong>Country:</strong>
            <%= listing.country %>
          </p>

         <% if(
          currUser &&
          (
            (listing.owner && listing.owner._id.equals(currUser._id)) ||
            review.author._id.equals(currUser._id)
          )
        ){ %>
          <div class="d-flex gap-2 mt-3">
            <a
              href="/listings/<%= listing._id %>/edit"
              class="btn btn-warning"
            >
              Edit
            </a>

            <form
              method="POST"
              action="/listings/<%= listing._id %>?_method=DELETE"
            >
              <button class="btn btn-danger">
                Delete
              </button>
            </form>
          </div>

          <% } %>

        </div>
      </div>
    </div>
  </div>

  <hr class="mt-5">

  <!-- Review Form -->
  <% if(currUser){ %>

  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <h4 class="mb-3">Leave a Review</h4>

      <form
        method="POST"
        action="/listings/<%= listing._id %>/reviews"
        class="needs-validation"
        novalidate
      >

        <div class="mb-3">

          <label class="form-label">
            Rating
          </label>

          <div class="star-rating">

            <input type="radio" name="review[rating]" value="5" id="star5" required>
            <label for="star5"><i class="bi bi-star-fill"></i></label>

            <input type="radio" name="review[rating]" value="4" id="star4">
            <label for="star4"><i class="bi bi-star-fill"></i></label>

            <input type="radio" name="review[rating]" value="3" id="star3">
            <label for="star3"><i class="bi bi-star-fill"></i></label>

            <input type="radio" name="review[rating]" value="2" id="star2">
            <label for="star2"><i class="bi bi-star-fill"></i></label>

            <input type="radio" name="review[rating]" value="1" id="star1">
            <label for="star1"><i class="bi bi-star-fill"></i></label>

          </div>

        </div>

        <div class="mb-3">

          <label
            class="form-label"
            for="comment"
          >
            Comment
          </label>

          <textarea
            class="form-control"
            id="comment"
            name="review[comment]"
            rows="3"
            required
          ></textarea>

        </div>

        <button class="btn btn-dark">
          Submit Review
        </button>

      </form>

    </div>
  </div>

  <% } %>

  <hr class="mt-5">

  <!-- Reviews -->

  <h4 class="mb-3">Reviews</h4>

  <div class="row">

    <% for(let review of listing.reviews){ %>

    <div class="col-md-4 mb-3">

      <div class="card h-100 border-dark">

        <div class="card-body">

          <h6>
            <i class="fa-solid fa-user"></i>
            <%= review.author.username %>
          </h6>

          <h6>
            ⭐ <%= review.rating %>/5
          </h6>

          <p>
            <%= review.comment %>
          </p>

          <% if(
            currUser &&
            (
              listing.owner.equals(currUser._id) ||
              review.author._id.equals(currUser._id)
            )
          ){ %>

          <form
            method="POST"
            action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
          >
            <button class="btn btn-danger btn-sm">
              Delete
            </button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>
  </div>

  <hr class="mt-5">

  <!-- Map -->

  <div class="row justify-content-center">

    <div class="col-md-8 col-lg-6">

      <h3 class="mb-3">
        Where you'll be
      </h3>
      <div id="map"></div>
    </div>
  </div>
</div>

<script>
    const mapToken = "<%= mapToken %>";
</script>

<script src="/js/map.js"></script>